        "@typescript-eslint/eslint-plugin": "^5.19.0",
        "@typescript-eslint/parser": "^5.19.0",
        "eslint": "^8.13.0",
        "package-tls": "^1.2.2",
        "path": "^0.12.7",
        "rollup": "^2.70.1",
        "rollup-plugin-terser": "^7.0.2",
        "ts-node": "^10.7.0",
